{
  "$schema": "https://raw.githubusercontent.com/LuaLS/vscode-lua/master/setting/schema.json",
  "runtime": {
    "version": "LuaJIT"
  },
  "workspace": {
    "library": [
      "~/.local/share/nvim/site/pack/core/opt/wezterm-types"
    ],
    "checkThirdParty": false
  },
  "diagnostics": {
    "globals": ["wezterm"],
    "unusedLocalExcludes": ["_*"]
  },
  "completion": {
    "callSnippet": "Replace"
  },
  "hint": {
    "enable": true
  },
  "format": {
    "enable": false
  },
  "telemetry": {
    "enable": false
  }
}
