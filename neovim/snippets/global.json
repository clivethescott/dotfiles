{
  "dateUTC": {
    "prefix": "dateUTC",
    "description": "Display current UTC time",
    "body": [
      "${CURRENT_YEAR}-${CURRENT_MONTH}-${CURRENT_DATE}T${CURRENT_HOUR}:${CURRENT_MINUTE}:${CURRENT_SECOND}.0Z"
    ]
  },
  "epoch": {
    "prefix": "epoch",
    "description": "Display current unix epoch",
    "body": [
      "$CURRENT_SECONDS_UNIX"
    ]
  }
}
