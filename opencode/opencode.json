{
  "$schema": "https://opencode.ai/config.json",
  "lsp": true,
  "formatter": true,
  "instructions": ["CONTRIBUTING.md", "docs/*.md"],
  "permission": {
    "bash": {
      "*": "ask",
      "git rebase": "ask",
      "git rm": "ask",
      "git *": "allow",
      "npm *": "allow",
      "rm -rf *": "deny",
      "grep *": "allow",
      "rg *": "allow",
      "cat *": "allow",
      "head *": "allow",
      "fd *": "allow",
      "find *": "allow",
      "tail *": "allow",
      "wc *": "allow",
      "sort *": "allow",
      "uniq *": "allow",
      "jq *": "allow",
      "ls *": "allow",
      "less *": "allow",
      "bat *": "allow",
      "gh pr close *": "ask",
      "gh pr *": "allow",
      "gh api *": "allow",
      "nexus *": "allow",
      "jira issue delete *": "ask",
      "jira issue *": "allow",
      "devx *": "allow",
      "sbt *": "allow",
      "sbtn *": "allow"
    },
    "external_directory": {
      "*": "ask",
      "/tmp*": "allow",
      "/var/folders*": "allow",
      "~/IdeaProjects/*": "allow",
      "~/Code/*": "allow",
      "~/Downloads/*": "allow"
    },
    "read": {
      "*": "allow",
      "~/.config/fish/*.fish": "ask"
    },
    "edit": {
      "*": "ask",
      "~/IdeaProjects/*": "allow",
      "~/Code/*": "allow",
      "~/Downloads/*": "allow"
    }
  },
  "provider": {
    "amazon-bedrock": {
      "options": {
        "region": "eu-central-1",
        "profile": "twdc-bedrock-central"
      }
    }
  },
  "plugin": [
    "oh-my-openagent@latest"
  ],
  "mcp": {
  }
}
