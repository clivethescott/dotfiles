{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "bash": {
      "*": "ask",
      "git *": "allow",
      "npm *": "allow",
      "rm *": "deny",
      "grep *": "allow",
      "rg *": "allow",
      "jq *": "allow"
    },
    "external_directory": {
      "*": "ask",
    },
    "read": {
      "*": "allow",
      "~/.config/fish/*.fish": "ask",
    },
    "edit": {
      "*": "ask",
      "~/IdeaProjects/*": "allow",
      "~/Code/*": "allow"
    }
  }
}
