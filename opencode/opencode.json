{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "bash": {
      "*": "ask",
      "git *": "allow",
      "npm *": "allow",
      "rm *": "deny",
      "grep *": "allow",
      "rg *": "allow",
      "jq *": "allow",
      "ls *": "allow"
    },
    "external_directory": {
      "*": "ask",
      "/tmp*": "allow"
    },
    "read": {
      "*": "allow",
      "~/.config/fish/*.fish": "ask"
    },
    "edit": {
      "*": "ask",
      "~/IdeaProjects/*": "allow",
      "~/Code/*": "allow"
    }
  },
  "provider": {
    "amazon-bedrock": {
      "options": {
        "region": "eu-central-1",
        "profile": "twdc-bedrock-central"
      }
    }
  },
  "plugin": [
    "oh-my-openagent@latest"
  ]
}
